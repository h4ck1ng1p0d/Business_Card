<!doctype html>
<html>
<head>
    <title>Email Signiture
    </title>

    <meta charset="utf-8" />
    <meta http-equiv="Content-type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style type="text/css">
        
        body{
            margin: 0;
            padding: 0;
        }
           
        .Business_card, .other, .buttonBox {
            width: 300px;
            height: 250px;
            background-color: #f1f1f1;
            margin: 5em auto;
            margin-top: 10px;
        }

        .other {
            margin: auto auto;
            height: 80px;
        }
        
        .buttonBox {
            margin: auto;
            height: 50px;
            text-align: center;
            margin-top: -70px;
        }

        p{
            font-family: Arial, Helvetica, sans-serif;
        }

        img {
            width: 300px;
        }

        p.green {
            color: darkgreen;
        }

        p.darkgreen {
            color: #000;
        }

        p {
            margin-top: 0;
            margin-bottom: 0;
        }

        .underl {
            margin: 0 0 10px 0;
        }

        .devider {
            margin: 50px;
        }
        .Business_card_text,
        .Business_card_text:visited,
        .Business_card_text:active {
            text-decoration: none;
            color: #000;
        }

        .aButton, .aButton:link, .aButton:visited {
        background-color: white;
        color: #000;
        border: 2px solid #000;
        padding: 10px 20px;
        text-align: center;
        text-decoration: none;
        display: inline-block;
        margin-top: 5px;
        }

        .aButton:hover, .aButton:active {
        background-color: #000;
        color: white;
        cursor: pointer;
        }
    </style>    
</head>

<body>
    

    <div class="other">
        <h1>Digital Business Card</h1>
    </div>
    <div class="Business_card">
    <img src="https://thehackingipod.tk/pixels.png">
    <p>Ethical Hacker Since 2019</p>

<p class="underl">............................................................</p>

    <p>Contact Information:</p>
    <p>Email: <a class="Business_card_text" href="mailto:hackingipod@protonmail.com">hackingipod@protonmail.com<a></p>
    <p>Reddit: <a class="Business_card_text" href="https://www.reddit.com/user/hacking_ipod/">@hacking_ipod</a></p>
    <p>Twitter: <a class="Business_card_text" href="https://twitter.com/HackingiPod1738">@HackingiPod1738</a></p>
    
    <br>
    <img src="https://thehackingipod.tk/Email_Signiture.png">

    </div>

    <div class="buttonBox">
        <a class="aButton">Download Me</a>
    </div>
</body>
</html>

